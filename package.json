{
  "name": "n8n-nodes-agent-pro",
  "version": "3.4.0",
  "description": "Advanced n8n AI Agent node for Claude, OpenAI & Gemini — native PDF/image vision, Claude Max (Claude Code OAuth) support, Anthropic prompt caching, structured output with auto-fix, fallback models, and on-demand document fetch.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "ai",
    "ai-agent",
    "agent",
    "llm",
    "claude",
    "claude-code",
    "claude-max",
    "claude-code-oauth",
    "anthropic",
    "openai",
    "gemini",
    "pdf",
    "vision",
    "multimodal",
    "structured-output",
    "langchain"
  ],
  "license": "MIT",
  "author": {
    "name": "SquareSigns"
  },
  "homepage": "https://github.com/Adanielyan92/n8n-nodes-agent-pro#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adanielyan92/n8n-nodes-agent-pro.git"
  },
  "bugs": {
    "url": "https://github.com/Adanielyan92/n8n-nodes-agent-pro/issues"
  },
  "main": "dist/nodes/AgentPro/AgentPro.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ClaudeVisionApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AgentPro/AgentPro.node.js",
      "dist/nodes/ClaudeVision/ClaudeVision.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.svg\" dist/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "package": "npm run build && npm pack",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "n8n-core": "^1.70.0",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.10"
  }
}
