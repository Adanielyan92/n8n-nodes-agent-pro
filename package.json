{
  "name": "n8n-nodes-agent-pro",
  "version": "3.3.19",
  "description": "Advanced AI Agent node for n8n with native PDF/image support, structured prompts, fallback models, prompt caching, and provider-agnostic sub-node architecture.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai",
    "agent",
    "llm",
    "claude",
    "claude-code",
    "anthropic",
    "openai",
    "gemini",
    "pdf",
    "vision",
    "multimodal",
    "langchain"
  ],
  "license": "MIT",
  "author": {
    "name": "SquareSigns"
  },
  "main": "dist/nodes/AgentPro/AgentPro.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ClaudeVisionApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AgentPro/AgentPro.node.js",
      "dist/nodes/ClaudeVision/ClaudeVision.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.svg\" dist/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "package": "npm run build && npm pack",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "n8n-core": "^1.70.0",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.10"
  }
}
